rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId || isAdmin();
    }

    match /inviteCodes/{code} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && !isParent();
      allow update: if request.auth.uid == resource.data.authorId || isAdmin();
      allow delete: if request.auth.uid == resource.data.authorId || isAdmin();

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth.uid == resource.data.authorId || isAdmin();
      }
    }

    match /events/{eventId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isTrainerOrGuide();
    }

    match /evaluationForms/{formId} {
      allow read: if isAdmin() || isTrainerOrGuide();
      allow create: if isTrainerOrGuide() || isAdmin();
      allow update: if isTrainerOrGuide() || isAdmin();
    }

    match /gallery/{itemId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && !isParent();
      allow delete: if request.auth.uid == resource.data.authorId || isAdmin();
    }

    match /liveVideos/{videoId} {
      allow read: if request.auth != null;
      allow create: if isVolunteerOrGuide();
      allow delete: if request.auth.uid == resource.data.authorId || isAdmin();
    }

    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth.uid == resource.data.authorId || isAdmin();

      match /answers/{answerId} {
        allow read: if request.auth != null;
        allow create: if isTrainerOrGuide();
        allow delete: if request.auth.uid == resource.data.authorId || isAdmin();
      }
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return request.auth != null && getRole() == 'admin';
    }
    function isParent() {
      return request.auth != null && getRole() == 'parent';
    }
    function isTrainerOrGuide() {
      return request.auth != null && getRole() in ['trainer', 'guide', 'admin'];
    }
    function isVolunteerOrGuide() {
      return request.auth != null && getRole() in ['volunteer', 'guide', 'admin'];
    }
  }
}
